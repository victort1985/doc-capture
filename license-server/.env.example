# Port the license server listens on
PORT=4100

# Paste the PRIVATE key printed by `npm run keygen` here.
# NEVER commit this file with a real key filled in.
# Keep the literal \n line breaks if pasting as one line, or use an
# actual multi-line PEM block — either works, server.js normalizes it.
LICENSE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Random long string, used to sign the admin panel's own login
# session tokens (separate from the license-signing key above).
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET=

# Path to a PERSISTENT clone of the main Vixor ERP repo on this
# machine — used by the "New tenant" / "Deploy now" buttons in the
# admin UI. See README.md's provisioning section for the sudoers
# setup this also requires.
VIXOR_REPO_DIR=/opt/vixor-repo

# Only needed if tenant instances can't reach this license server at
# localhost:<PORT> — e.g. they're on a different host.
# PUBLIC_LICENSE_SERVER_URL=https://license.example.com

# Automates adding/removing each new tenant's subdomain on your
# existing Cloudflare Tunnel (the one already serving app.doc-capture.app
# and license.doc-capture.app) — skips the manual dashboard step of
# adding a Public Hostname for every new customer. See README.md's
# Cloudflare automation section for how to get these.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_TUNNEL_ID=
TENANT_BASE_DOMAIN=doc-capture.app
