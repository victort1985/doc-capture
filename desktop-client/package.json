{
  "name": "vixor-erp-desktop",
  "version": "1.0.0",
  "description": "Vixor ERP Desktop Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "app.doc-capture.vixor-erp",
    "productName": "Vixor ERP",
    "copyright": "Copyright © 2026 Vixor",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "assets/**"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business"
    },
    "linux": {
      "target": [
        {
          "target": "dir",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "electronVersion": "40.10.5",
    "publish": "never"
  },
  "devDependencies": {
    "electron": "40.10.5",
    "electron-builder": "^25.1.8"
  },
  "author": "Viktor Tykhonov <victort1985@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/victort1985/doc-capture"
  }
}