# Server
PORT=3000
NODE_ENV=development

# TLS — if both are set to valid file paths, the server terminates HTTPS
# directly (no reverse proxy needed). Leave unset for plain HTTP (fine for
# a fully isolated LAN; otherwise see the installation guide for how to
# generate a certificate — self-signed is fine for internal use).
# TLS_CERT_PATH=
# TLS_KEY_PATH=

# Comma-separated list of allowed origins for the admin panel/API, e.g.
# https://admin.example.com. Leave unset and only the local Vite dev-server
# origins are allowed — the packaged admin panel is always same-origin
# with the API anyway, so this normally only matters during development.
# CORS_ORIGIN=

# JWT
# Leave as "change_me" (or unset) and the server will generate a real
# random secret on first run and save it back here automatically — no
# manual step needed, but you can still set your own value if you prefer.
JWT_SECRET=change_me
JWT_EXPIRES_IN=7d

# Encryption key (AES-256) used to encrypt storage-connection passwords at
# rest, and optionally uploaded file contents (see STORAGE_ENCRYPT_NOTE in
# the admin operations guide). Same auto-generate-and-save behavior as
# JWT_SECRET above — leave as "change_me" unless you have a reason to set
# your own.
ENCRYPTION_KEY=change_me

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=doc_capture
# Set to true if DB_HOST is a remote/cloud database reachable over a
# network you don't fully trust. Leave false for a local/same-machine
# Postgres (the typical setup from the installation guide).
DB_SSL=false
# Only relevant if DB_SSL=true. Set to false ONLY for providers that use
# self-signed certificates — leave true (default) for any real CA-signed
# certificate.
DB_SSL_REJECT_UNAUTHORIZED=true

# Uploads
MAX_FILE_SIZE_MB=20

# How long (ms) to wait on a single FTP/WebDAV network operation before
# treating it as failed, so a slow/unreachable NAS can't hang an upload
# request indefinitely.
STORAGE_OPERATION_TIMEOUT_MS=15000
