# --- Mobile client (Flutter) ---
# Native platform folders are intentionally NOT committed — they're
# regenerated on demand via `flutter create .` (see installation-guide.md
# and .github/workflows/mobile-build.yml, which does this automatically).
mobile-client/android/
mobile-client/ios/
mobile-client/macos/
mobile-client/windows/
mobile-client/linux/
mobile-client/web/
mobile-client/build/
mobile-client/.dart_tool/
mobile-client/.flutter-plugins
mobile-client/.flutter-plugins-dependencies
mobile-client/.packages
mobile-client/pubspec.lock
mobile-client/lib/l10n/app_localizations*.dart
mobile-client/*.iml

